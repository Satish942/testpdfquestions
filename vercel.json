{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/upload.mjs": {
      "maxDuration": 120,
      "memory": 1024,
      "includeFiles": "node_modules/pdf-parse/node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    },
    "api/generate-exam.mjs": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/exam-history.mjs": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
